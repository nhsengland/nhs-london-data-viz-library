{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationDir": "dist-lib/types",
    "emitDeclarationOnly": true,
    "outDir": "dist-lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/nhs-viz/**/*"],
  "exclude": ["node_modules", "dist", "dist-lib", "src/**/*.test.tsx", "src/**/*.test.ts"]
}
