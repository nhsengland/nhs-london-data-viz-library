{
  "name": "nhs-london-data-viz-library",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "main": "dist-lib/index.js",
  "module": "dist-lib/index.js",
  "types": "dist-lib/types/nhs-viz/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/index.js",
      "types": "./dist-lib/types/nhs-viz/index.d.ts"
    },
    "./sub-navigation.css": "./src/nhs-viz/sub-navigation/sub-navigation.css"
  },
  "files": [
    "dist-lib",
    "src/nhs-viz/sub-navigation/sub-navigation.css"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && tsc --project tsconfig.lib.json",
    "dev": "vite",
    "dev:remote": "vite --mode code-workspaces",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint --report-unused-disable-directives --max-warnings 0 --fix",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.0.0"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "nhsuk-frontend": "^10.4.2",
    "nhsuk-react-components": "^6.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.35.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint-plugin-jsx-a11y": "^6.10.0",
    "@types/node": "^24.10.13",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "typescript": "~5.5.4",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
